  labs(x = "Gene Count", y = "Pathway", title = "KEGG Pathway Enrichment") +
  theme_minimal() +
  theme(
    axis.text.y = element_text(size = 10),
    axis.title = element_text(size = 12, face = "bold"),
    plot.title = element_text(size = 14, face = "bold", hjust = 0.5),
    legend.position = "right",
    legend.text = element_text(size = 9),
    legend.title = element_text(size = 10, face = "bold")
  )
print(p_bar)
dev.off()

summary_data <- data.frame(
  Pathway_ID = data$ID,
  Pathway_Name = substr(data$Description, 1, 60),
  Category = if ("category" %in% colnames(data)) data$category else "N/A",
  Subcategory = if ("subcategory" %in% colnames(data)) data$subcategory else "N/A",
  Gene_Count = data$Count,
  Rich_Factor = round(data$RichFactor, 3),
  P_Value = format(data$pvalue, scientific = TRUE, digits = 3),
