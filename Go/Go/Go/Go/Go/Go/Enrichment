kegg <- KEGG_selected[, c("Description", "Count", "pvalue", "GeneRatio")]
kegg$GeneRatio_numeric <- sapply(kegg$GeneRatio, function(x) {
  parts <- strsplit(as.character(x), "/")[[1]]
  as.numeric(parts[1]) / as.numeric(parts[2])
})

sankey <- KEGG_selected[, c("Description", "geneID")]
sankey <- sankey %>%
  separate_rows(geneID, sep = "/") %>%
  filter(!is.na(geneID) & geneID != "" & geneID != "NA")

kegg2 <- kegg[nrow(kegg):1, ]
kegg2 <- kegg2 %>%
  mutate(
    ymax = cumsum(Count),
    ymin = ymax - Count,
    label = (ymin + ymax) / 2,
    Description_short = ifelse(
      nchar(Description) > 40,
      paste0(substr(Description, 1, 37), "..."),
      Description
    )
  )

mytheme <- theme(
  axis.title = element_text(size = 13),
  axis.text = element_text(size = 11),
  axis.text.y = element_blank(),
  axis.ticks.y = element_blank(),
  legend.title = element_text(size = 13),
  legend.text = element_text(size = 11),
  plot.title = element_text(size = 14, face = "bold", hjust = 0.5)
)

p_bubble <- ggplot() +
  geom_point(
    data = kegg2,
    aes(
      x = -log10(pvalue),
      y = label,
      size = Count,
      color = GeneRatio_numeric
    ),
    alpha = 0.8
  ) +
  scale_size_continuous(
    name = "Gene Count",
    range = c(3, 10),
    breaks = pretty(range(kegg2$Count))
  ) +
  scale_y_continuous(
    expand = expansion(mult = c(0, 0.1)),
    limits = c(0, max(kegg2$ymax) + 5)
  ) +
  scale_x_continuous(
    limits = c(0.1, ceiling(max(-log10(kegg2$pvalue))) + 1)
  ) +
  scale_color_gradientn(
    name = "Gene Ratio",
    colors = brewer.pal(9, "Reds"),
    guide = guide_colorbar(title.position = "top", title.hjust = 0.5)
  ) +
  labs(
    x = "-log10(P-value)",
    y = "",
    title = "KEGG Pathway Enrichment"
  ) +
  theme_bw() +
  mytheme +
  geom_text(
    data = kegg2,
    aes(
      x = -log10(pvalue) + max(-log10(pvalue)) * 0.05,
      y = label,
      label = Description_short
    ),
    hjust = 0,
    size = 3.5,
    color = "black",
    fontface = "italic"
  )

ggsave("KEGG_Bubble_Plot_Final.pdf", p_bubble, width = 8, height = 9, dpi = 600)

df <- sankey %>%
  make_long(geneID, Description)

pathway_levels <- unique(sankey$Description) %>% rev()
gene_levels <- unique(sankey$geneID) %>% rev()
df$node <- factor(df$node, levels = c(pathway_levels, gene_levels))

n_colors <- length(unique(df$node))
mycol <- if (n_colors <= 12) {
  brewer.pal(max(3, n_colors), "Set3")
} else {
  colorRampPalette(brewer.pal(12, "Set3"))(n_colors)
}

tryCatch({
  p_sankey <- ggplot(df, aes(
    x = x,
    next_x = next_x,
    node = node,
    next_node = next_node,
    fill = node,
    label = node
  )) +
    geom_sankey(
      flow.alpha = 0.5,
      flow.fill = 'grey70',
      flow.color = 'grey50',
      smooth = 8,
      width = 0.08
    ) +
    geom_sankey_text(
      size = 3.0,
      color = "black"
    ) +
    scale_fill_manual(values = mycol) +
    theme_void() +
    theme(
      legend.position = 'none',
      plot.margin = margin(0, 80, 0, 0),
      plot.title = element_text(size = 14, face = "bold", hjust = 0.5, margin = margin(b = 10))
    ) +
    labs(title = "Gene-Pathway Associations")
  
  ggsave("KEGG_Sankey_Plot_MethodA.pdf", p_sankey, width = 12, height = 9, dpi = 600)
  
}, error = function(e) {
  p_sankey_base <- ggplot(df, aes(
    x = x,
    next_x = next_x,
    node = node,
    next_node = next_node,
    fill = node
  )) +
    geom_sankey(
      flow.alpha = 0.5,
      flow.fill = 'grey70',
      flow.color = 'grey50',
      smooth = 8,
      width = 0.08,
      show.legend = FALSE
    ) +
    scale_fill_manual(values = mycol) +
    theme_void() +
    theme(
      legend.position = 'none',
      plot.margin = margin(0, 80, 0, 0)
    )
  
  create_sankey_labels <- function(sankey_df) {
    all_genes <- unique(sankey_df$geneID)
    all_pathways <- unique(sankey_df$Description)
    
    gene_labels <- data.frame(
      label = all_genes,
      x = 0.15,
      y = seq(0.15, 0.85, length.out = length(all_genes)),
      hjust = 1,
      type = "Gene",
      stringsAsFactors = FALSE
    )
    
    pathway_labels <- data.frame(
      label = all_pathways,
      x = 0.85,
      y = seq(0.15, 0.85, length.out = length(all_pathways)),
      hjust = 0,
      type = "Pathway",
      stringsAsFactors = FALSE
    )
    
    rbind(gene_labels, pathway_labels)
  }
  
  label_data <- create_sankey_labels(sankey)
  
  p_sankey <- p_sankey_base +
    geom_text(
      data = label_data[label_data$type == "Gene", ],
      aes(x = x, y = y, label = label),
      hjust = 1,
      size = 2.8,
      color = "black",
      nudge_x = -0.02,
      check_overlap = FALSE
    ) +
    geom_text(
      data = label_data[label_data$type == "Pathway", ],
      aes(x = x, y = y, label = label),
      hjust = 0,
      size = 3.0,
      color = "black",
      fontface = "italic",
      nudge_x = 0.02,
      check_overlap = FALSE
    ) +
    scale_x_continuous(limits = c(-0.1, 1.1)) +
    labs(title = "Gene-Pathway Associations") +
    theme(plot.title = element_text(size = 14, face = "bold", hjust = 0.5, margin = margin(b = 10)))
  
  ggsave("KEGG_Sankey_Plot_MethodB.pdf", p_sankey, width = 12, height = 9, dpi = 600)
})

if(file.exists("KEGG_Sankey_Plot_MethodA.pdf")) {
  tryCatch({
    p_sankey_final <- ggplot(df, aes(
      x = x,
      next_x = next_x,
      node = node,
      next_node = next_node,
      fill = node,
      label = node
    )) +
      geom_sankey(
        flow.alpha = 0.5,
        flow.fill = 'grey70',
        flow.color = 'grey50',
        smooth = 8,
        width = 0.08
      ) +
      geom_sankey_text(
        size = 3.0,
        color = "black"
      ) +
      scale_fill_manual(values = mycol) +
      theme_void() +
      theme(
        legend.position = 'none',
        plot.margin = margin(0, 80, 0, 0)
      )
    
    p_combined <- ggdraw() + 
      draw_plot(p_sankey_final) + 
      draw_plot(
        p_bubble, 
        scale = 0.5, 
        x = 0.50, 
        y = -0.17, 
        width = 0.68, 
        height = 1.3
      ) +
      draw_label(
        "KEGG Pathway Analysis", 
        x = 0.5, 
        y = 0.97, 
        size = 16, 
        fontface = "bold"
      )
    
    ggsave("KEGG_Combined_Plot.pdf", p_combined, width = 14, height = 9, dpi = 600)
  }, error = function(e) {})
}

summary_data <- data.frame(
  Pathway_ID = data$ID,
  Pathway_Name = substr(data$Description, 1, 60),
  Category = if ("category" %in% colnames(data)) data$category else "N/A",
  Subcategory = if ("subcategory" %in% colnames(data)) data$subcategory else "N/A",
  Gene_Count = data$Count,
  Rich_Factor = round(data$RichFactor, 3),
  P_Value = format(data$pvalue, scientific = TRUE, digits = 3),
  FDR = if ("p.adjust" %in% colnames(data)) format(data$p.adjust, scientific = TRUE, digits = 3) else "N/A",
  log10_Pvalue = round(data$log10pval, 2)
)

write.table(summary_data, file = "KEGG_summary_table.txt", sep = "\t", quote = FALSE, row.names = FALSE)

summary_table <- data.frame(
  Rank = 1:nrow(kegg2),
  Pathway = kegg2$Description_short,
  Pathway_ID = KEGG_selected$ID,
  Category = KEGG_selected$category,
  Gene_Count = kegg2$Count,
  P_Value = formatC(kegg2$pvalue, format = "e", digits = 2),
  `-log10_P` = round(-log10(kegg2$pvalue), 2),
  Gene_Ratio = round(kegg2$GeneRatio_numeric, 4),
  Rich_Factor = round(KEGG_selected$RichFactor, 3),
  Associated_Genes = sapply(KEGG_selected$geneID, function(x) {
    genes <- strsplit(x, "/")[[1]]
    paste(head(genes, 5), collapse = ", ")
  }),
  stringsAsFactors = FALSE
)

write.table(summary_table, file = "KEGG_Analysis_Summary_Final.txt", 
            sep = "\t", quote = FALSE, row.names = FALSE)
