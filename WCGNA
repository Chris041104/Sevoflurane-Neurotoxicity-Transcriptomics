sink("WGCNA_analysis_summary.txt")
cat("WGCNA Analysis Summary\n")
cat("=====================\n\n")
cat("Analysis date:", date(), "\n")
cat("Data file: Exp_details.xlsx\n")
cat("Samples analyzed:", paste(rownames(datExpr0), collapse = ", "), "\n")
cat("Number of samples:", nSamples, "\n")
cat("Number of genes analyzed (after low expression filter):", nGenes, "\n")
cat("Low expression filter: rowMeans > 0.5\n")
