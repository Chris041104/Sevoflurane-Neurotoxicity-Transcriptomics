# 加载R包
library(limma)
library(WGCNA)
library(openxlsx)

# 设置工作目录
setwd("/Volumes/LENOVO/Thesis 5")

# 读取Excel文件
data_raw <- read.xlsx("Exp_details.xlsx", sheet = 1)

# 查看数据结构
head(data_raw)
dim(data_raw)
colnames(data_raw)  # 查看所有列名

# 提取表达矩阵 - 只保留0.7MAC和2MAC的样本（共6个样本）
# 根据实际输出，列名是"0.7MAC.-.1"、"0.7MAC.-.2"等格式
expr_cols <- c("0.7MAC.-.1", "0.7MAC.-.2", "0.7MAC.-.3", 
               "2MAC.-.1", "2MAC.-.2", "2MAC.-.3")

# 检查列是否存在
available_cols <- expr_cols[expr_cols %in% colnames(data_raw)]
cat("找到的样本列:", paste(available_cols, collapse = ", "), "\n")

if (length(available_cols) == 0) {
  # 如果没找到，尝试其他可能的列名格式
  cat("尝试其他列名格式...\n")
  
  # 方法1：包含点号的格式
  possible_cols <- grep("0.7MAC|2MAC", colnames(data_raw), value = TRUE)
  cat("包含MAC的列:", paste(possible_cols, collapse = ", "), "\n")
  
  # 如果有找到，使用这些列
  if (length(possible_cols) >= 6) {
    available_cols <- possible_cols
  } else {
    stop("无法找到0.7MAC和2MAC的样本列")
  }
}

# 提取表达数据
expr_data <- data_raw[, available_cols, drop = FALSE]
rownames(expr_data) <- data_raw$Gene.ID  # 使用Gene ID作为行名

# 转换为矩阵
expr_matrix <- as.matrix(expr_data)
dimnames(expr_matrix) <- list(rownames(expr_matrix), colnames(expr_matrix))

# 检查数据分布
cat("数据范围:\n")
print(summary(as.vector(expr_matrix)))

# 去除低表达的基因：使用rowMeans > 0.5（参考代码的标准）
keep_genes <- rowMeans(expr_matrix) > 0.5
cat("保留基因的条件: rowMeans > 0.5\n")
cat("保留的基因数量:", sum(keep_genes, na.rm = TRUE), "\n")
cat("去除的低表达基因数量:", sum(!keep_genes, na.rm = TRUE), "\n")

expr_matrix <- expr_matrix[keep_genes, , drop = FALSE]
dim(expr_matrix)

# 创建样本信息 - 用于后续的性状分析
sample_names <- colnames(expr_matrix)
group_info <- data.frame(
  Sample = sample_names,
  Condition = ifelse(grepl("0.7MAC", sample_names), "lowMAC", "highMAC"),
  Group_num = ifelse(grepl("0.7MAC", sample_names), 0, 1)  # 0.7MAC=0, 2MAC=1
)
rownames(group_info) <- sample_names
print(group_info)

# 转置数据：WGCNA需要样本为行，基因为列
datExpr0 <- t(expr_matrix)

# 确保数据是数值型
datExpr0 <- as.matrix(datExpr0)
storage.mode(datExpr0) <- "numeric"

# 检查缺失值
gsg <- goodSamplesGenes(datExpr0, verbose = 3)
gsg$allOK
if (!gsg$allOK) {
  if (sum(!gsg$goodGenes) > 0)
    printFlush(paste("Removing genes:", paste(names(datExpr0)[!gsg$goodGenes], collapse = ", ")))
  if (sum(!gsg$goodSamples) > 0)
    printFlush(paste("Removing samples:", paste(rownames(datExpr0)[!gsg$goodSamples], collapse = ", ")))
  datExpr0 <- datExpr0[gsg$goodSamples, gsg$goodGenes]
}

# 样本聚类 - 检查离群值
sampleTree <- hclust(dist(datExpr0), method = "average")
pdf(file = "1_sample_cluster.pdf", width = 12, height = 9)
par(cex = 0.6)
par(mar = c(0, 4, 2, 0))
plot(sampleTree, main = "Sample clustering to detect outliers", sub = "", xlab = "", 
     cex.lab = 1.5, cex.axis = 1.5, cex.main = 2)
# 添加颜色标记
sample_colors <- ifelse(grepl("0.7MAC", sample_names), "blue", "red")
colored_branches <- sample_colors[sampleTree$order]
dev.off()

# 根据聚类结果，设置cutHeight删除离群样本
# 可以根据实际聚类图调整cutHeight
cutHeight <- 150  # 可以根据实际聚类图调整
pdf(file = "1_sample_cluster_with_cut.pdf", width = 12, height = 9)
par(cex = 0.6)
par(mar = c(0, 4, 2, 0))
plot(sampleTree, main = "Sample clustering with cut line", sub = "", xlab = "", 
     cex.lab = 1.5, cex.axis = 1.5, cex.main = 2)
abline(h = cutHeight, col = "red")
dev.off()

