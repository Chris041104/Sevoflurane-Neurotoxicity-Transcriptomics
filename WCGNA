cat("\nTop 10 hub genes (by |GS|) across all modules:\n")

# 收集所有模块的核心基因
all_hub_genes <- data.frame()
for (module_color in unique(moduleColors)) {
  hub_file <- paste0("hubGenes_", module_color, ".txt")
  if (file.exists(hub_file)) {
    hub_data <- read.table(hub_file, header = TRUE, sep = "\t")
    all_hub_genes <- rbind(all_hub_genes, hub_data)
  }
}
if (nrow(all_hub_genes) > 0) {
  all_hub_genes <- all_hub_genes[order(-abs(all_hub_genes$GS)), ]
  print(head(all_hub_genes[, c("Feature.ID", "Gene.ID", "Module", "GS", "Log2FC")], 10))
}
